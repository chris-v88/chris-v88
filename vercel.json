{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/version", "destination": "/version.json" },
    { "source": "/config", "destination": "/index.html" },
    { "source": "/wiki", "destination": "/index.html" },
    { "source": "/docs", "destination": "/index.html" }
  ]
}
